---
import { getCollection, render } from "astro:content";
import Base from "../../../layouts/Base.astro";
import { t } from "../../../i18n/utils";

export async function getStaticPaths() {
  const posts = await getCollection("postsPtBr");
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={post.data.title} description={post.data.description} locale="pt-br">
  <article class="post-page">
    <header class="post-header">
      <a href="/pt-br/" class="back-link">{t("pt-br", "backLink")}</a>
      <h1>{post.data.title}</h1>
      <time datetime={post.data.date}>
        {new Date(post.data.date + "T00:00:00").toLocaleDateString("pt-BR", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })}
      </time>
      {post.data.tags.length > 0 && (
        <div class="tags" aria-label="Tags">
          {post.data.tags.map((tag: string) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}
    </header>
    <div class="post-content">
      <Content />
    </div>
  </article>
</Base>
