---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { t } from "../../i18n/utils";

const posts = (await getCollection("postsPtBr")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Base title="Blog" locale="pt-br">
  <h1 class="page-title">{t("pt-br", "homeHeading")}</h1>
  <section class="post-list">
    {posts.map((post) => (
      <article class="post-card">
        <a class="post-link" href={`/pt-br/posts/${post.data.slug}`}>
          <time datetime={post.data.date}>
            {new Date(post.data.date + "T00:00:00").toLocaleDateString("pt-BR", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })}
          </time>
          <span class="post-summary">
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
          </span>
        </a>
      </article>
    ))}
  </section>
</Base>
