---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A minimalist blog" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="layout">
      <header>
        <a href="/" class="site-title">Gustavo Miranda</a>
        <p class="tagline">Software engineer writing about web development, tools, and things I learn along the way.</p>
      </header>
      <main>
        <slot />
      </main>
      <footer>
        <p>&copy; {new Date().getFullYear()}</p>
        <nav class="social-links">
          <a href="#">GitHub</a>
          <span>·</span>
          <a href="#">LinkedIn</a>
          <span>·</span>
          <a href="#">Email</a>
        </nav>
      </footer>
    </div>
  </body>
</html>
